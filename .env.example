# FIRE Capital Tools — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Generate a strong random key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to true only during local development
FLASK_DEBUG=false

# Set via create_admin.py — run it once and paste the output hash here
ADMIN_USERNAME=michelle
ADMIN_PASSWORD_HASH=

# Required for FIRE Metrics Census/ACS data refreshes
CENSUS_API_KEY=your_census_api_key_here

# Optional: where Scorecard Pro's per-property upload history/trend data is
# stored (SQLite). Set this to a persistent volume path in production, the
# same way FIRE_METRICS_DB_PATH does for FIRE Metrics' own database.
SCORECARD_PRO_DB_PATH=scorecard_pro_history.db

# Optional: where Deal Dive's deals/comps/condition data is stored (SQLite).
# Set this to a persistent volume path in production, same as above.
DEAL_DIVE_DB_PATH=deal_dive.db

# Required for the market data service (RentCast rent estimates/comps/
# property details + Google Places ratings/reviews) used by Deal Dive's
# "Auto-Pull Market Data" action. Sign up at rentcast.io for a key; get a
# Places API key from the Google Cloud Console. Falls back to a local
# rentcast_api_key.txt / google_places_api_key.txt file at the repo root
# (gitignored) if not set here.
RENTCAST_API_KEY=your_rentcast_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Optional: where the RentCast/Google Places lookup cache is stored
# (SQLite). RentCast's free tier is 50 calls/month, so lookups are cached
# for 30 days by default -- set this to a persistent volume path in
# production so the cache survives deploys.
MARKET_DATA_DB_PATH=market_data_cache.db
